<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Колір при виборі (активний) -->
    <item android:color="@color/primary" android:state_checked="true" />
    <!-- Колір при натисканні -->
    <item android:color="@color/primary" android:state_pressed="true" />
    <!-- Колір при виділенні -->
    <item android:color="@color/primary" android:state_selected="true" />
    <!-- Колір за замовчуванням (неактивний) -->
    <item android:color="@color/text_secondary" />
</selector>