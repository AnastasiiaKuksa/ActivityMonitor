<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Заголовок тривалості сну -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Тривалість сну"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Скільки годин ви спали?"
        android:textSize="14sp"
        android:textColor="#666"
        android:layout_marginBottom="12dp" />

    <!-- Поле введення тривалості -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSleepDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Години (наприклад: 7.5)"
            android:inputType="numberDecimal"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Заголовок якості сну -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Якість сну"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Як добре ви спали?"
        android:textSize="14sp"
        android:textColor="#666"
        android:layout_marginBottom="16dp" />

    <!-- Слайдер якості сну -->
    <com.google.android.material.slider.Slider
        android:id="@+id/sliderSleepQuality"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="1"
        android:valueTo="4"
        android:stepSize="1"
        android:value="3"
        android:layout_marginBottom="16dp" />

    <!-- Підписи для слайдера - ВИПРАВЛЕНА ВЕРСІЯ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" Погано"
            android:textSize="12sp"
            android:gravity="center"
            android:textAlignment="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" Задовільно"
            android:textSize="12sp"
            android:gravity="center"
            android:textAlignment="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" Добре"
            android:textSize="12sp"
            android:gravity="center"
            android:textAlignment="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" Відмінно"
            android:textSize="12sp"
            android:gravity="center"
            android:textAlignment="center" />

    </LinearLayout>

</LinearLayout>